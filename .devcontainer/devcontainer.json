{
    "name": "Zephyr Development",
    "image": "ghcr.io/zephyrproject-rtos/zephyr-build:main",
    "remoteUser": "user",
    "workspaceFolder": "/workdir",
    "mounts": [
        "source=${localWorkspaceFolder},target=/workdir,type=bind"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "marus25.cortex-debug",
                "ms-vscode.cpptools"
            ]
        }
    }
}

